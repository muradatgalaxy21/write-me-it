# Provider fallback order: gemini-2.5-flash -> gemini-2.5-flash-lite -> groq.

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_SECONDARY=gemini-2.5-flash-lite

# Get a free key at https://console.groq.com/keys (last-resort fallback)
GROQ_API_KEY=your_key_here

# Model used for the Groq fallback. See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback output cap per call if a stage budget below is unset.
GROQ_MAX_TOKENS=2048

# Per-agent output token budgets. Each stage capped on its own so no single agent
# (e.g. the outline writer) eats the whole allowance. Tune freely.
# Critic/editor are split per phase: the BLOG critic/editor echo the FULL text of
# one post, so they need more room than the OUTLINE phase. Too small => the model
# truncates mid-JSON and Groq rejects with json_validate_failed.
BUDGET_OUTLINE=1000
BUDGET_BLOG=1500
BUDGET_CRITIC_OUTLINE=1200
BUDGET_CRITIC_BLOG=2200
BUDGET_EDITOR_OUTLINE=1200
BUDGET_EDITOR_BLOG=2200
