# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_key_here

# Model used for all agents. See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Max output tokens per call. One call returns 2 items (outlines, then full blogs);
# 4096 gives headroom for the longer blog stage. Lower = cheaper/shorter.
GROQ_MAX_TOKENS=4096
