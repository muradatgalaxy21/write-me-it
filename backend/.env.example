# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_key_here

# Model used for all 3 agents. See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Max output tokens per call. One call returns all 3 drafts (~200 tokens each),
# so 2048 gives headroom for the heavier critic stage. Lower = cheaper/shorter.
GROQ_MAX_TOKENS=2048
